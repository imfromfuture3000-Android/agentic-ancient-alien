# ============================================================
# Agentic Futarchy Markets — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
CONTROLLER_KEYPAIR=~/.config/solana/controller.json
PROGRAM_ID=YOUR_DEPLOYED_PROGRAM_ID_HERE

# Colosseum Copilot (Research API)
COLOSSEUM_COPILOT_API_BASE=https://copilot.colosseum.com/api/v1
COLOSSEUM_COPILOT_PAT=your_colosseum_pat_here

# OpenAI (for AI Agent features)
OPENAI_API_KEY=your_openai_api_key_here

# GitHub (for automated workflows)
GH_TOKEN=your_github_pat_here
